{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pom.local/schemas/wiki-annotation.schema.json",
  "title": "POM Wiki Annotation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "annotationId",
    "createdAt",
    "updatedAt",
    "status",
    "target",
    "selectedText",
    "annotation",
    "history"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1"
    },
    "annotationId": {
      "type": "string",
      "pattern": "^annotation-[a-z0-9-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["new", "triaged", "in_progress", "resolved", "parked", "discarded"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "heading", "lineStart", "lineEnd"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "heading": {
          "type": "string"
        },
        "lineStart": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "lineEnd": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "selectedText": {
      "type": "string"
    },
    "annotation": {
      "type": "string",
      "minLength": 1
    },
    "requestedAction": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "takenBy": {
      "type": ["string", "null"]
    },
    "takenAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "resolvedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "resolution": {
      "type": "string"
    },
    "agentReport": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["processedAt", "by", "summary"],
      "properties": {
        "processedAt": {
          "type": "string",
          "format": "date-time"
        },
        "by": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "status", "by", "note"],
        "properties": {
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["new", "triaged", "in_progress", "resolved", "parked", "discarded"]
          },
          "by": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
