stateDiagram-v2
  direction LR

  %% Workflow: operational_fsm
  %% Syntonia ai-agent pipeline orchestrator.

  state "Safety Pre Screen" as safety_pre_screen
  state "Question Normalizer" as question_normalizer
  state "Analyzer" as analyzer
  state "Execution Contract" as execution_contract
  state "Sql Generator" as sql_generator
  state "Execute And Validate" as execute_and_validate
  state "Output Generator" as output_generator

  [*] --> safety_pre_screen

  safety_pre_screen --> question_normalizer : pre_screen_passed
  safety_pre_screen --> [*] : non_business_signal
  question_normalizer --> analyzer : normalized
  analyzer --> execution_contract : analyzer_done_full_pipeline
  analyzer --> output_generator : analyzer_done_direct_output
  analyzer --> [*] : clarification_signal
  analyzer --> [*] : analyzer_block_signal
  analyzer --> [*] : non_business_signal
  analyzer --> [*] : loop_guard_signal
  execution_contract --> sql_generator : contract_built
  sql_generator --> execute_and_validate : sql_generated
  sql_generator --> [*] : policy_block_signal
  sql_generator --> [*] : sql_refusal_signal
  sql_generator --> [*] : loop_guard_signal
  execute_and_validate --> output_generator : execution_validated
  execute_and_validate --> [*] : sql_refusal_signal
  execute_and_validate --> [*] : loop_guard_signal
  output_generator --> [*] : answer_rendered

