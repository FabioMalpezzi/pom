    completed → analyzer_done_full_pipeline, deterministic_reply_resolved → analyzer_done_direct_output, pending_scope_resolved → analyzer_done_direct_output, llm_failure → analyzer_block_signal, parse_exhausted → analyzer_block_signal, schema_exhausted → analyzer_block_signal, coherence_exhausted → analyzer_block_signal
