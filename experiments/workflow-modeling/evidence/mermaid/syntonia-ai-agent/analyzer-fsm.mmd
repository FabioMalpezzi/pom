stateDiagram-v2
  direction LR

  %% Workflow: analyzer_fsm
  %% Syntonia ai-agent analyzer.

  state "Signal Extraction" as signal_extraction
  state "Ml Family Classification" as ml_family_classification
  state "Deterministic Reply Check" as deterministic_reply_check
  state "Contextual Followup Check" as contextual_followup_check
  state "Pending Scope Resolution" as pending_scope_resolution
  state "Llm Call" as llm_call
  state "Parse And Validate" as parse_and_validate
  state "Signal Merge" as signal_merge
  state "Scope Resolution" as scope_resolution
  state "Deterministic Repairs" as deterministic_repairs
  state "Entity Grounding" as entity_grounding
  state "Family Enforcement" as family_enforcement
  state "Coherence Validation" as coherence_validation

  [*] --> signal_extraction

  signal_extraction --> ml_family_classification : signals_extracted
  ml_family_classification --> deterministic_reply_check : ml_hint_applied
  deterministic_reply_check --> contextual_followup_check : deterministic_check_done
  contextual_followup_check --> pending_scope_resolution : followup_check_done
  pending_scope_resolution --> llm_call : pending_scope_proceeded
  llm_call --> parse_and_validate : llm_responded
  parse_and_validate --> signal_merge : parse_ok
  signal_merge --> scope_resolution : signals_merged
  scope_resolution --> deterministic_repairs : scope_applied
  deterministic_repairs --> entity_grounding : repairs_applied
  entity_grounding --> family_enforcement : entities_grounded
  family_enforcement --> coherence_validation : family_enforced
  coherence_validation --> [*] : coherence_ok
  deterministic_reply_check --> [*] : deterministic_reply_found
  pending_scope_resolution --> [*] : pending_scope_resolved_directly
  parse_and_validate --> llm_call : parse_retry
  coherence_validation --> llm_call : coherence_retry
  llm_call --> [*] : llm_call_failed
  parse_and_validate --> [*] : parse_attempts_exhausted
  parse_and_validate --> [*] : schema_attempts_exhausted
  coherence_validation --> [*] : coherence_attempts_exhausted

  note right of family_enforcement
    invokes clean_family_repair_fsm
    family_ready → family_enforced, needs_scope_clarification → family_enforced, needs_semantic_clarification → family_enforced, blocked → family_enforced, exhausted → family_enforced
  end note
