stateDiagram-v2
  direction LR

  %% Workflow: semantic_family_fsm
  %% High-level FamilyState graph used by the internal AI agent semantic layer.

  state "Turn Received" as turn_received
  state "Family Candidate" as family_candidate
  state "Needs Scope Clarification" as needs_scope_clarification
  state "Needs Semantic Clarification" as needs_semantic_clarification
  state "Family Ready" as family_ready

  [*] --> turn_received

  turn_received --> family_candidate : classify\n[any_entry_guard_matches]
  turn_received --> [*] : block_signal\n[any_block_guard]
  family_candidate --> needs_scope_clarification : scope_missing_signal\n[scope_missing]
  family_candidate --> needs_semantic_clarification : semantic_ambiguity_signal\n[any_semantic_ambiguity]
  family_candidate --> family_ready : ready_guards_matched\n[all_ready_guards_for_candidate]
  family_candidate --> [*] : block_signal\n[any_block_guard]
  needs_scope_clarification --> family_candidate : scope_resolved
  needs_semantic_clarification --> family_candidate : semantic_resolved
  family_ready --> [*] : turn_finalized
