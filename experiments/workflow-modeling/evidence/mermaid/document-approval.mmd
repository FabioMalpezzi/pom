stateDiagram-v2
  direction LR

  %% Workflow: document_approval
  %% Lifecycle of an internal document that goes through review, approval, and publication.

  state "Draft" as draft
  state "Reviewer Assigned" as reviewer_assigned
  state "In Review" as in_review
  state "Approved" as approved
  state "Rejected" as rejected
  state "Published" as published

  [*] --> draft

  draft --> reviewer_assigned : assign_reviewer
  draft --> [*] : withdraw
  reviewer_assigned --> in_review : start_review
  in_review --> approved : approve\n[is_approver]
  in_review --> rejected : reject\n[is_approver]
  in_review --> draft : request_revisions\n[is_approver]
  approved --> published : publish\n[has_required_signoffs]
  approved --> [*] : archive
  published --> [*] : archive
  rejected --> [*] : archive
