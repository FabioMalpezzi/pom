{
  "id": "semantic_family_master",
  "initial": "turn_received",
  "states": {
    "turn_received": {
      "description": "Turn received, classification not started.",
      "on": {
        "start_classification": "evaluating_gating_or_clarification"
      }
    },
    "evaluating_gating_or_clarification": {
      "description": "Position 1 in the precedence sequence. Terminator family;\nforwards a hard block immediately to the master's blocked terminal.",
      "invoke": {
        "id": "invoke_evaluating_gating_or_clarification",
        "src": "family_gating_or_clarification",
        "input": {
          "signals": "signals",
          "scope_context": "scope_context",
          "role_family": "role_family"
        },
        "onDone": [
          {
            "guard": "_terminal_eq_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "gating_matched"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_blocked",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "gating_blocked"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_not_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "try_cascade_bridge"
                  }
                }
              }
            ]
          }
        ]
      },
      "on": {
        "gating_matched": "family_resolved",
        "gating_blocked": "blocked",
        "try_cascade_bridge": "evaluating_cascade_bridge"
      }
    },
    "evaluating_cascade_bridge": {
      "description": "Position 2: cascade-bridge analytical family.",
      "invoke": {
        "id": "invoke_evaluating_cascade_bridge",
        "src": "family_cascade_bridge",
        "input": {
          "signals": "signals",
          "scope_context": "scope_context",
          "role_family": "role_family"
        },
        "onDone": [
          {
            "guard": "_terminal_eq_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_matched"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_scope_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_scope"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_semantic_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_semantic"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_not_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "try_yoy_driver_diagnosis"
                  }
                }
              }
            ]
          }
        ]
      },
      "on": {
        "family_matched": "family_resolved",
        "family_needs_scope": "needs_scope_clarification",
        "family_needs_semantic": "needs_semantic_clarification",
        "try_yoy_driver_diagnosis": "evaluating_yoy_driver_diagnosis"
      }
    },
    "evaluating_yoy_driver_diagnosis": {
      "description": "Position 3: yoy-driver-diagnosis family.",
      "invoke": {
        "id": "invoke_evaluating_yoy_driver_diagnosis",
        "src": "family_yoy_driver_diagnosis",
        "input": {
          "signals": "signals",
          "scope_context": "scope_context",
          "role_family": "role_family"
        },
        "onDone": [
          {
            "guard": "_terminal_eq_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_matched"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_scope_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_scope"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_semantic_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_semantic"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_not_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "try_rolling_trend_tradeoff"
                  }
                }
              }
            ]
          }
        ]
      },
      "on": {
        "family_matched": "family_resolved",
        "family_needs_scope": "needs_scope_clarification",
        "family_needs_semantic": "needs_semantic_clarification",
        "try_rolling_trend_tradeoff": "evaluating_rolling_trend_tradeoff"
      }
    },
    "evaluating_rolling_trend_tradeoff": {
      "description": "Position 4: rolling-trend-tradeoff family.",
      "invoke": {
        "id": "invoke_evaluating_rolling_trend_tradeoff",
        "src": "family_rolling_trend_tradeoff",
        "input": {
          "signals": "signals",
          "scope_context": "scope_context",
          "role_family": "role_family"
        },
        "onDone": [
          {
            "guard": "_terminal_eq_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_matched"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_scope_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_scope"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_semantic_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_semantic"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_not_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "try_benchmark_vs_media"
                  }
                }
              }
            ]
          }
        ]
      },
      "on": {
        "family_matched": "family_resolved",
        "family_needs_scope": "needs_scope_clarification",
        "family_needs_semantic": "needs_semantic_clarification",
        "try_benchmark_vs_media": "evaluating_benchmark_vs_media"
      }
    },
    "evaluating_benchmark_vs_media": {
      "description": "Position 5: benchmark-vs-media family.",
      "invoke": {
        "id": "invoke_evaluating_benchmark_vs_media",
        "src": "family_benchmark_vs_media",
        "input": {
          "signals": "signals",
          "scope_context": "scope_context",
          "role_family": "role_family"
        },
        "onDone": [
          {
            "guard": "_terminal_eq_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_matched"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_scope_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_scope"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_semantic_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_semantic"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_not_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "try_ratio_threshold_ranking"
                  }
                }
              }
            ]
          }
        ]
      },
      "on": {
        "family_matched": "family_resolved",
        "family_needs_scope": "needs_scope_clarification",
        "family_needs_semantic": "needs_semantic_clarification",
        "try_ratio_threshold_ranking": "evaluating_ratio_threshold_ranking"
      }
    },
    "evaluating_ratio_threshold_ranking": {
      "description": "Position 6: ratio-threshold-ranking family.",
      "invoke": {
        "id": "invoke_evaluating_ratio_threshold_ranking",
        "src": "family_ratio_threshold_ranking",
        "input": {
          "signals": "signals",
          "scope_context": "scope_context",
          "role_family": "role_family"
        },
        "onDone": [
          {
            "guard": "_terminal_eq_matched",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_matched"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_scope_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_scope"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_needs_semantic_clarification",
            "actions": [
              {
                "type": "raise",
                "params": {
                  "event": {
                    "type": "family_needs_semantic"
                  }
                }
              }
            ]
          },
          {
            "guard": "_terminal_eq_not_matched",
            "actions": [
